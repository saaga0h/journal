# Application
APP_NAME=journal
APP_VERSION=0.1.0
APP_ENV=development

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Postgres
DB_HOST=localhost
DB_PORT=5433
DB_USER=journal
DB_PASSWORD=journal
DB_NAME=journal
DB_SSLMODE=disable

# MQTT
MQTT_BROKER_URL=tcp://localhost:1884
MQTT_CLIENT_ID=journal

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_CHAT_MODEL=qwen2.5:7b
OLLAMA_CHAT_NUM_CTX=32768
OLLAMA_TIMEOUT=60

# Association threshold for entry-standing document similarity (0.0 - 1.0)
ASSOCIATION_THRESHOLD=0.3
