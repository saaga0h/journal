{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "packageRules": [
    {
      "matchCategories": [
"docker"
      ],
      "pinDigests": true
    },
    {
      "matchCategories": ["golang"],
      "enabled": true
    },
    {
      "matchCategories": [
        "docker"
      ],
      "pinDigests": true
    },
    {
      "matchUpdateTypes": [
        "major"
      ],
      "dependencyDashboardApproval": true
    },
    {
      "groupName": "golang.org/x packages",
      "groupSlug": "golang-x",
      "matchPackageNames": [
"golang.org/x/{/,}**"
      ]
    },
    {
      "groupName": "jackc packages",
      "matchPackageNames": [
        "github.com/jackc/{/,}**"
      ]
    },
    {
      "matchUpdateTypes": ["patch"],
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": true,
      "matchPackageNames": [
        "*"
      ]
    },
    {
      "matchUpdateTypes": ["minor"],
      "minimumReleaseAge": "5 days",
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": true,
      "matchPackageNames": [
        "*"
      ]
    },
    {
      "matchUpdateTypes": [
        "major"
      ],
      "automerge": false,
      "dependencyDashboardApproval": true
    },
    {
      "matchManagers": [
        "dockerfile",
        "docker-compose"
      ],
      "automerge": false
    },
    {
      "groupName": "golang.org/x packages",
      "automerge": true,
      "minimumReleaseAge": "3 days",
      "matchPackageNames": ["golang.org/x/{/,}**"]
    }
  ],
  "prConcurrentLimit": 5,
  "gomod": {
    "enabled": true
  }
}
